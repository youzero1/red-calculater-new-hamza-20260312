describe('formatResult', () => {
  it('returns "Error" for Error input', () => {
    expect(formatResult('Error')).toBe('Error');
  });

  it('returns "Error" for Infinity', () => {
    expect(formatResult(Infinity)).toBe('Error');
  });

  it('returns "Error" for -Infinity', () => {
