  });

  it('multiplies with * character', () => {
    expect(calculate(3, 7, '*')).toBe(21);
  });

  it('divides with ÷ character', () => {
    expect(calculate(20, 4, '÷')).toBe(5);
  });

  it('divides with / character', () => {
    expect(calculate(20, 4, '/')).toBe(5);
  });

  it('returns Error for division by zero (÷)', () => {
    expect(calculate(5, 0, '÷')).toBe('Error');
  });

  it('returns Error for division by zero (/)', () => {
    expect(calculate(5, 0, '/')).toBe('Error');
  });

  it('handles modulo operator', () => {
    expect(calculate(10, 3, '%')).toBe(1);
  });

  it('returns Error for modulo by zero', () => {
    expect(calculate(10, 0, '%')).toBe('Error');
  });

  it('returns second operand for unknown operator', () => {
    expect(calculate(5, 3, '?')).toBe(3);
  });

  it('handles negative results', () => {
    expect(calculate(3, 10, '−')).toBe(-7);
  });

  it('handles decimal addition', () => {
    expect(calculate(0.1, 0.2, '+')).toBeCloseTo(0.3);
