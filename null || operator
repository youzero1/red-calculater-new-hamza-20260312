  });

  it('formats simple decimal correctly', () => {
    expect(formatResult(3.14)).toBe('3.14');
  });

  it('truncates long decimals to 10 places', () => {
    const result = formatResult(1 / 3);
    const parts = result.split('.');
    expect(parts[1].length).toBeLessThanOrEqual(10);
  });

  it('formats zero correctly', () => {
